# Postgres (matches docker-compose.yml — host port 5544 to avoid clashing with other local Postgres)
DATABASE_URL=postgres://arena:arena@localhost:5544/arena
# Set DATABASE_SSL=true for managed Postgres (AWS RDS/Aurora, Neon, …). Leave unset for local Docker.
DATABASE_SSL=
# Bound the connection pool on serverless (Vercel). Keep small (e.g. 3) or use RDS Proxy.
DB_POOL_MAX=

# WorkOS AuthKit — populate locally (https://dashboard.workos.com)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=   # >=32 chars, generate with: openssl rand -base64 32
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Only members of this WorkOS organization may use the app:
ALLOWED_ORG_ID=

# Generation — native drivers (dispatched by model_provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Local dev / e2e auth bypass (NEVER set in production) ────────────────────
# Leave ALL THREE blank/unset to use real WorkOS. To bypass WorkOS locally:
#   NEXT_PUBLIC_ARENA_DEV_AUTH=1  → middleware skips WorkOS (edge runtime needs the public flag)
#   ARENA_DEV_AUTH_EMAIL=you@org  → requireUser resolves this dev user (Node runtime)
#   ARENA_DEV_AUTH_ROLE=admin     → role for the dev user (defaults to admin)
NEXT_PUBLIC_ARENA_DEV_AUTH=
ARENA_DEV_AUTH_EMAIL=
ARENA_DEV_AUTH_ROLE=admin
